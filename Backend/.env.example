DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=medisync

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# minutos sin confirmar tras los que una toma pasa a OMITIDA
INTAKE_AUTO_OMIT_MINUTES=30
# minutos que suma POSPONER a fecha_programada
INTAKE_POSTPONE_MINUTES=10
# intervalo del job en background que recorre tomas vencidas
SCHEDULER_INTERVAL_MINUTES=5

# umbral mínimo de calidad de señal (0-100) para aceptar una lectura del wearable
VITAL_SIGN_MIN_QUALITY=50

CORS_ORIGINS=*
